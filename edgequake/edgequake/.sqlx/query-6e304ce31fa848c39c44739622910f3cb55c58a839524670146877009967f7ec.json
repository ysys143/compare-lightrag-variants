  "query": "\n            SELECT\n                pdf_id,\n                workspace_id,\n                document_id,\n                filename,\n                content_type,\n                file_size_bytes,\n                sha256_checksum,\n                page_count,\n                pdf_data,\n                processing_status,\n                extraction_method,\n                vision_model,\n                markdown_content,\n                extraction_errors,\n                created_at,\n                processed_at,\n                updated_at\n            FROM pdf_documents\n            WHERE workspace_id = $1 AND sha256_checksum = $2\n            LIMIT 1\n            ",
