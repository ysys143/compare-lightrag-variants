# EdgeQuake MCP Server Configuration
# Copy this file to .env and fill in your values

# ============================================
# API Endpoint  
# ============================================
EDGEQUAKE_BASE_URL=http://localhost:8080

# ============================================
# Authentication (Choose One)
# ============================================

# Option 1: API Key (recommended for services)
EDGEQUAKE_API_KEY=eq-key-YOUR-API-KEY-HERE

# Option 2: JWT Token (for user applications)
# EDGEQUAKE_ACCESS_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# Tenant & Workspace (Required for Multi-Tenant)
# ============================================

# If your API key can access multiple tenants, specify which one to use
# EDGEQUAKE_DEFAULT_TENANT=tenant-uuid-abc123

# If tenant has multiple workspaces, specify which one to use
# EDGEQUAKE_DEFAULT_WORKSPACE=workspace-uuid-xyz789

# ============================================
# LLM Configuration (Optional - per workspace default)
# ============================================

# LLM provider for entity extraction
# EDGEQUAKE_LLM_PROVIDER=ollama
# EDGEQUAKE_LLM_MODEL=gemma3:12b

# Embedding provider for vector search
# EDGEQUAKE_EMBEDDING_PROVIDER=ollama
# EDGEQUAKE_EMBEDDING_MODEL=nomic-embed-text

# ============================================
# Development Settings
# ============================================

# Enable debug logging
# DEBUG=edgequake:*

# Custom timeout (milliseconds)
# EDGEQUAKE_TIMEOUT=30000
