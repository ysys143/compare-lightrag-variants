# EdgeQuake WebUI Environment Configuration
# Copy this file to .env.local and update the values

# API Configuration
# The base URL for the EdgeQuake API server
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional: Default tenant ID for multi-tenant deployments
# NEXT_PUBLIC_DEFAULT_TENANT_ID=default

# Optional: Feature flags
# NEXT_PUBLIC_ENABLE_DEMO_MODE=true
# NEXT_PUBLIC_ENABLE_API_EXPLORER=true
