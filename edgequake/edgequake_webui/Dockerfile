# EdgeQuake Frontend Dockerfile
# Multi-stage build for Next.js application

# ============================================
# Stage 1: Dependencies
# ============================================
FROM node:20-alpine AS deps

WORKDIR /app

# Copy package files
COPY edgequake_webui/package.json edgequake_webui/pnpm-lock.yaml ./

# Install dependencies with pnpm
RUN npm install -g pnpm && pnpm install --frozen-lockfile

# ============================================
# Stage 2: Build
# ============================================
FROM node:20-alpine AS builder

# Build args for Next.js public environment variables
ARG NEXT_PUBLIC_API_URL=http://localhost:8080

WORKDIR /app

# Copy package files
COPY edgequake_webui/package.json edgequake_webui/pnpm-lock.yaml ./

# Install pnpm
RUN npm install -g pnpm

# Copy dependencies from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy configuration files
# NOTE: next-env.d.ts is auto-generated by `next build` — do not COPY it
COPY edgequake_webui/package.json ./
COPY edgequake_webui/pnpm-lock.yaml ./
COPY edgequake_webui/next.config.ts ./
COPY edgequake_webui/tsconfig.json ./
COPY edgequake_webui/postcss.config.mjs ./
COPY edgequake_webui/components.json ./
COPY edgequake_webui/eslint.config.mjs ./
COPY edgequake_webui/vitest.config.mjs ./

# Copy source directories
COPY edgequake_webui/src ./src
COPY edgequake_webui/public ./public

# Set Next.js public environment variables for build time
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Build application directly with next build (bypass safe-build.sh for Docker)
RUN npx next build

# ============================================
# Stage 3: Runtime
# ============================================
FROM node:20-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create non-root user
RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001

# Copy package files (including lock file for frozen install)
COPY edgequake_webui/package.json edgequake_webui/pnpm-lock.yaml ./

# Install pnpm and production dependencies only
RUN npm install -g pnpm && pnpm install --prod --frozen-lockfile

# Copy built application from builder
COPY --from=builder --chown=nextjs:nodejs /app/.next ./.next
COPY --from=builder --chown=nextjs:nodejs /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/node_modules ./node_modules

# Switch to non-root user
USER nextjs

# Expose frontend port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000 || exit 1

# Start Next.js server
CMD ["pnpm", "start"]
