# Ignore everything except what we need
**/.git
**/.github
**/.vscode
**/.claude
**/.pytest_cache
**/.playwright-mcp
**/target
**/node_modules
**/__pycache__
**/logs
**/test-results
**/archive
**/docs
**/docs_retro
**/audit_*
**/lightrag
**/lightrag_webui
**/open-webui
**/plan_*
**/sessions
**/specs
**/tech_stack
**/ux_ui_map
**/zz_test_docs
**/zz-explore
**/articles
**/*.log
**/*.md
!**/README.md
**/*.py
**/*.sh
!**/scripts/*.sh

# Allow necessary JSON files
!**/package.json
!**/tsconfig.json
!**/next.config.ts
!**/components.json

# Explicitly exclude frontend build artifacts
edgequake_webui/node_modules
edgequake_webui/.next
edgequake_webui/out
edgequake_webui/dist
edgequake_webui/build
edgequake_webui/coverage
edgequake_webui/test-results
edgequake_webui/playwright-report
edgequake_webui/.playwright
edgequake_webui/*.pid
edgequake_webui/*.txt
!edgequake_webui/package.json
!edgequake_webui/pnpm-lock.yaml


